pkgname="carbonio-openjdk-cacerts"
pkgver="3.113" # renovate: datasource=repology depName=nss
pkgrel="1"
pkgdesc="CA Certs keystore for OpenJDK"
arch=('x86_64')
maintainer="Zextras <packages@zextras.com>"
url="https:/zextras.com"
depends=(
  "carbonio-openjdk"
)
makedepends=("perl")
section="utils"
license=("MPL-2.0")
priority="optional"
source=(
  "https://raw.githubusercontent.com/nss-dev/nss/NSS_${pkgver/./_}_RTM/lib/ckfw/builtins/certdata.txt"
  "ca-bundle.crt"
  "import-cacerts.pl"
  "systemd-tmpfile.conf"
)
sha256sums=(
  'b6cb65afb95d1a4f328f3fc05bc2050ae38ff4e6c95e5854de84dcc74025790d'
  '7e3333d066c0e10348ce78b6ab9ecb44cad72b1bd6c664e1f9f20fec71ff6cf0'
  'ef6dcacb1c0ae92a23c53fe036fbaf236726e0659f3e4bac2ed2a26bdc0d1d74'
  'd27d62d96f984f7e898c920df28485702a9fb0b51fe22cef4e1474416aaaced2'
)

package() {
  mkdir -p "${pkgdir}/opt/zextras/common/etc/java"

  cd "${srcdir}"

  # Convert certdata.txt to PKCS12 der certificates compatible with
  # OpenJDK keystore
  ./import-cacerts.pl -f certdata.txt -o \
    "${pkgdir}"/opt/zextras/common/etc/java

  install -Dm 644 "certdata.txt" \
    "${pkgdir}/opt/zextras/common/etc/java/"
  install -Dm 644 "ca-bundle.crt" \
    "${pkgdir}/opt/zextras/common/etc/java/"

  # systemd tmpfiles.d
  install -Dm644 "${srcdir}/systemd-tmpfile.conf" \
    "${pkgdir}/usr/lib/tmpfiles.d/${pkgname}.conf"
}

preinst__apt() {
  if [ "$1" = "upgrade" ]; then
    if [ "$2" != "$3" ]; then
      cacerts_save_dir="/opt/zextras/.saveconfig/carbonio-openjdk-cacerts"
      if [ ! -d "${cacerts_save_dir}" ]; then
        mkdir -p "${cacerts_save_dir}"
      else
        rm -f ${cacerts_save_dir}/*
      fi
      cacerts_backup=${cacerts_save_dir}/cacerts-$(date +"%Y%m%d")
      cp /opt/zextras/common/etc/java/cacerts "$cacerts_backup"

      # Marker file to indicate in postinstall that an update was done
      touch /opt/zextras/common/etc/java/.upgrade
    fi
  fi
}

preinst__yum() {
  if [ "$1" == "2" ]; then
    cacerts_save_dir="/opt/zextras/.saveconfig/carbonio-openjdk-cacerts"
    if [ ! -d "${cacerts_save_dir}" ]; then
      mkdir -p "${cacerts_save_dir}"
    else
      rm -f ${cacerts_save_dir}/*
    fi
    cacerts_backup=${cacerts_save_dir}/cacerts-$(date +"%Y%m%d")

    cp /opt/zextras/common/etc/java/cacerts "$cacerts_backup"

    # Marker file to indicate in postinstall that an update was done
    touch /opt/zextras/common/etc/java/.upgrade
  fi
}

postinst__apt() {
  # zextras user/group provided by carbonio-core via sysusers.d
  # cacerts ownership/permissions handled by tmpfiles.d
  systemd-tmpfiles --create /usr/lib/tmpfiles.d/carbonio-openjdk-cacerts.conf >/dev/null 2>&1 || :

  if [ -f /opt/zextras/common/etc/java/.upgrade ]; then
    rm -f /opt/zextras/common/etc/java/.upgrade

    cacerts_save_dir="/opt/zextras/.saveconfig/carbonio-openjdk-cacerts"
    cacerts_backup=${cacerts_save_dir}/cacerts-$(date +"%Y%m%d")

    mailboxd_truststore_password=$(su - zextras -c "zmlocalconfig -s -m nokey mailboxd_truststore_password")
    if [ -x /opt/zextras/bin/zmcertmgr ]; then
      # Extract CA to /opt/zextras/conf/ca
      su - zextras -c '/opt/zextras/bin/zmcertmgr createca'
      # Update OpenJDK cacerts file with the CA stored in LDAP
      su - zextras -c '/opt/zextras/bin/zmcertmgr deployca --localonly'

      if [ "$mailboxd_truststore_password" != "changeit" ]; then
        su - zextras -c "/opt/zextras/common/bin/keytool -storepasswd -keystore /opt/zextras/common/etc/java/cacerts -storepass changeit -new $mailboxd_truststore_password"
      fi

      if [ -d "$cacerts_save_dir" ]; then
        chown zextras:zextras "$cacerts_backup"
        chmod 644 "$cacerts_backup"

        echo "Restoring certificates after upgrades from latest backup:"
        echo "$cacerts_backup"
        echo "please wait..."

        # Extracts only local CA certificates
        for cert in $(/opt/zextras/common/bin/keytool -list -keystore "$cacerts_backup" -storepass changeit | grep trustedCertEntry | grep "zcs\|my_ca" | grep -Eo "^[^,]*"); do
          /opt/zextras/common/bin/keytool \
            -exportcert \
            -keystore "$cacerts_backup" \
            -storepass changeit \
            -alias "$cert" \
            -file "$cacerts_save_dir/$cert" 2>/dev/null

          # Check if it's self-signed or commercial certificate using ca-bundle.crt,
          # created with https://curl.se/docs/mk-ca-bundle.html
          isValid=$(openssl x509 -inform der -in "$cacerts_save_dir/$cert" -outform pem | openssl verify -CAfile /opt/zextras/common/etc/java/ca-bundle.crt 2>&1)

          if [ "$isValid" = "stdin: OK" ]; then
            echo "Skip commercial cert $cert"
          else
            caData=$(echo "$isValid" | grep -v 'error')
            org=$(echo "$caData" | sed 's/= /=/g' | cut -f 4 -d '=')
            # Sometimes openssl does not recognize all commercial certificates using verify so this check in the certdata.txt
            # Maybe this check is not perfect but usually it removes lot of wrong imports
            if grep -q "$org" /opt/zextras/common/etc/java/certdata.txt; then
              echo "Skip unrecognized commercial CA $org $cert"
            else
              echo "Importing self-signed CA cert $cert"
              chown zextras:zextras "$cacerts_save_dir/$cert"
              su - zextras -c "/opt/zextras/bin/zmcertmgr addcacert $cacerts_save_dir/$cert" >/dev/null
            fi
          fi
        done
      fi
    fi
  fi
}

postinst__yum() {
  # zextras user/group provided by carbonio-core via sysusers.d
  # cacerts ownership/permissions handled by tmpfiles.d
  systemd-tmpfiles --create /usr/lib/tmpfiles.d/carbonio-openjdk-cacerts.conf >/dev/null 2>&1 || :

  if [ -f /opt/zextras/common/etc/java/.upgrade ]; then
    rm -f /opt/zextras/common/etc/java/.upgrade

    cacerts_save_dir="/opt/zextras/.saveconfig/carbonio-openjdk-cacerts"
    cacerts_backup=${cacerts_save_dir}/cacerts-$(date +"%Y%m%d")

    mailboxd_truststore_password=$(su - zextras -c "zmlocalconfig -s -m nokey mailboxd_truststore_password")
