          # created with https://curl.se/docs/mk-ca-bundle.html
          isValid=$(openssl x509 -inform der -in "$cacerts_save_dir/$cert" -outform pem | openssl verify -CAfile /opt/zextras/common/etc/java/ca-bundle.crt 2>&1)

          if [ "$isValid" == "stdin: OK" ]; then
            echo "Skip commercial cert $cert"
          else
            caData=$(echo "$isValid" | grep -v 'error')
            org=$(echo "$caData" | sed 's/= /=/g' | cut -f 4 -d '=')
